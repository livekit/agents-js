{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "allowJs": false,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true
  },
  "typedocOptions": {
    "entryPoints": ["agents", "plugins/*"],
    "entryPointStrategy": "packages",
    "name": "LiveKit Agents",
    "packageOptions": {
      "excludeInternal": true,
      "excludePrivate": true,
      "excludeProtected": true,
      "excludeExternals": true,
      "includeVersion": true,
      "out": "docs",
      "theme": "default",
      "validation": {
        "notExported": false,
        "notDocumented": true
      },
      "requiredToBeDocumented": [
        "Enum",
        "Function",
        "Class",
        "Interface",
        "Method"
      ],
      "treatValidationWarningsAsErrors": true,
    }
  }
}
