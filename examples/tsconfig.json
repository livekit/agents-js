{
  "extends": "../tsconfig.json",
  "include": ["./src"],
  // `src/test_*.ts` are git-ignored local scratch files (see .gitignore); keep
  // them out of the package build so they can't break `pnpm build`.
  "exclude": ["./src/test_*.ts"],
  "compilerOptions": {
    // match output dir to input dir. e.g. dist/index instead of dist/src/index
    "rootDir": "./src",
    "declarationDir": "./dist",
    "outDir": "./dist"
  }
}
