new file mode 100644
index 0000000000..2303dc871c
--- /dev/null
+++ b/livekit-agents/livekit/agents/language.py
@@ -0,0 +1,129 @@
+# Copyright 2023 LiveKit, Inc.
+#
+# Licensed under the Apache License, Version 2.0 (the "License");
